{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "pip_requirements",
    "github-actions"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge semver minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
