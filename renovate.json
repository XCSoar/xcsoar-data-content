{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "github-actions",
    "pip_requirements",
    "pre-commit"
  ],
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "automerge": true,
      "description": "Automerge semver minor and patch updates",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ],
  "platformAutomerge": true
}
